<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Teyes Battery Monitor"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvHeaderSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Интеллектуальный контроль разряда АКБ"
            android:textColor="#94A3B8"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvHeaderTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Current Voltage Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardVoltage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#1E293B"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvHeaderSub">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="НАПРЯЖЕНИЕ БОРТОВОЙ СЕТИ"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvCurrentVoltage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--.- V"
                    android:textColor="#38BDF8"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Обновляется каждые 10 сек из MCU шины"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Threshold Settings Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#1E293B"
            app:layout_constraintTop_toBottomOf="@id/cardVoltage">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ПОРОГ СРАБАТЫВАНИЯ"
                    android:textColor="#38BDF8"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Критический предел:"
                        android:textColor="#E2E8F0"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvThresholdValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:text="11.8 V"
                        android:textColor="#F43F5E"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <SeekBar
                    android:id="@+id/seekBarThreshold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:max="15"
                    android:progress="8" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Рекомендуемый диапазон: 11.6V - 12.0V"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:gravity="center" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Service Control -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchAutostart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Запускать автоматически при включении"
            android:textColor="#E2E8F0"
            android:textSize="15sp"
            android:checked="true"
            app:layout_constraintTop_toBottomOf="@id/cardSettings" />

        <Button
            android:id="@+id/btnToggleService"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:text="Запустить мониторинг"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#22C55E"
            android:textAllCaps="false"
            app:layout_constraintTop_toBottomOf="@id/switchAutostart" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
